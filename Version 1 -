<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Franc</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #ffffff;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
    }

    .title {
      font-size: 80px;
      font-weight: bold;
      margin-bottom: 40px;
      letter-spacing: 2px;
    }

    .search-box {
      width: 100%;
      max-width: 600px;
      display: flex;
      border: 1px solid #ccc;
      border-radius: 30px;
      padding: 10px 20px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .search-box input {
      flex: 1;
      border: none;
      outline: none;
      font-size: 18px;
    }

    .search-box button {
      border: none;
      background: #4285f4;
      color: white;
      padding: 8px 16px;
      border-radius: 20px;
      cursor: pointer;
    }

    .search-box button:hover {
      background: #3367d6;
    }
  </style>
</head>
<body>

  <div class="title">Franc</div>

  <form class="search-box">
    <input type="text" placeholder="Rechercher sur Franc...">
    <button type="submit">Rechercher</button>
  </form>

</body>
</html>
